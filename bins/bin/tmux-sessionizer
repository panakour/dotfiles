#!/usr/bin/env fish

set PROJECT_ROOTS ~/Code ~/Projects
set EXTRA_PATHS ~ ~/learnworlds ~/Downloads ~/Documents

function bump_zoxide
    zoxide add $argv[1]
end

if test (count $argv) -eq 1
    set sel $argv[1]
else
    set sel (begin
        for path in $PROJECT_ROOTS
            test -d $path; and find $path -maxdepth 1 -mindepth 1 -type d -not -name '_*' 2>/dev/null
        end
        for proj in $EXTRA_PATHS
            test -d $proj; or continue
            if test "$proj" = "$HOME"
                echo "$proj (home)"
            else
                echo $proj
            end
        end
    end | sort -u | fzf-tmux -p --prompt "  ")
    set sel (string replace -r ' \(home\)$' '' -- $sel)
end

test -z "$sel"; and exit 0

if test "$sel" = "$HOME"
    set name home
else
    set name (string replace -a . _ (path basename $sel))
end

if not pgrep tmux >/dev/null
    tmux new -s $name -c $sel; and bump_zoxide $sel
    exit
end

if not tmux has-session -t=$name 2>/dev/null
    tmux new -ds $name -c $sel
end

tmux switch -t=$name
bump_zoxide $sel
